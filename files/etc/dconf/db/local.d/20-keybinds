[org/gnome/desktop/wm/keybindings]
close=['<Shift><Super>q']
switch-to-workspace-left=['<Super>h']
switch-to-workspace-right=['<Super>l']
move-to-workspace-left=['<Alt><Super>h']
move-to-workspace-right=['<Alt><Super>l']
move-to-monitor-left=['<Shift><Alt><Super>h']
move-to-monitor-down=['<Shift><Alt><Super>j']
move-to-monitor-up=['<Shift><Alt><Super>k']
move-to-monitor-right=['<Shift><Alt><Super>l']
switch-windows=['<Alt>Tab']
switch-windows-backward=['<Shift><Alt>Tab']

[org/gnome/settings-daemon/plugins/media-keys]
custom-keybindings=['/org/gnome/settings-daemon/plugins/media-keys/custom-keybindings/terminal/', '/org/gnome/settings-daemon/plugins/media-keys/custom-keybindings/mangohud/', '/org/gnome/settings-daemon/plugins/media-keys/custom-keybindings/suspend/']

[org/gnome/settings-daemon/plugins/media-keys/custom-keybindings/terminal]
binding='<Super>Return'
command='ptyxis --new-window'
name='Open terminal'

[org/gnome/settings-daemon/plugins/media-keys/custom-keybindings/suspend]
binding='<Super>ISO_Level3_Shift'
command='sh -c "[ -d /sys/class/power_supply/BAT0 ] && systemctl suspend"'
name='Suspend'
